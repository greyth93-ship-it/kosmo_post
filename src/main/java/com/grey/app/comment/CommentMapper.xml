  <delete id="delete" parameterType="CommentDTO">
  	DELETE FROM "TB_COMMENT"
  	WHERE "COMMENT_NO"=#{commentNo}
  </delete>
  
  <update id="update" parameterType="CommentDTO">
  	UPDATE "TB_COMMENT"
  	SET "COMMENT_CONTENT" = #{commentContent}
  	WHERE "COMMENT_NO"=#{commentNo}
  </update>
  
  
  
  
  
  
  
  
  
  
  
  
