  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.grey.app.comment.CommentMapper">
	<insert id="create" parameterType="CommentDTO">
  		INSERT INTO "TB_COMMENT"
  		VALUES (
  		default,
  		#{commentContent},
  		#{commentStar},
  		now(),
  		#{goodsNo},
  		#{username}
  		)
  	</insert>
  
  	<select id="list" parameterType="CommentDTO" resultType="commentDTO">
  		SELECT *
  		FROM "TB_COMMENT" 
  		<!-- LEFT JOIN "TB_MEMBER" m USING ("USERNAME")
  		LEFT JOIN "TB_GOODS" g ("GOODS_NO") -->
  		WHERE "GOODS_NO"=#{goodsNo}
  		ORDER BY "COMMENT_NO" DESC
  	</select>
  
