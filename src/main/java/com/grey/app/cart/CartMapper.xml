<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.grey.app.cart.CartMapper">
  	<insert id="create" parameterType="CartDTO">
  		INSERT INTO "TB_CART"
  		VALUES (
  			#{username},
  			#{goodsNo}
  		)
  	</insert>
  	
  	<select id="list" parameterType="MemberDTO" resultMap="joinResult">
  		SELECT g.*,f.* 
  		FROM "TB_CART" c
  		JOIN "TB_GOODS" g USING("GOODS_NO")
  		JOIN "TB_GOODSFILE" f USING("GOODS_NO")
  		WHERE "USERNAME"=#{username}
  	</select>
  	
  	<resultMap type="GoodsDTO" id="joinResult">
		<id column="GOODS_NO" property="goodsNo"/>
		<result column="GOODS_NAME" property="goodsName"/>
		<result column="GOODS_CONTENT" property="goodsContent"/>
		<result column="GOODS_CATEGORY" property="goodsCategory"/>
		<result column="GOODS_RATE" property="goodsRate"/>
		
		<association property="goodsfileDTO" javaType="GoodsFileDTO">
			<id column="FILE_NO" property="fileNo"/>
			<result column="FILE_NAME" property="fileName"/>
			<result column="ORI_NAME" property="oriName"/>
		</association>
	</resultMap>
	
	<delete id="delete" parameterType="java.util.List">
		DELETE FROM "TB_CART"
		<foreach collection="list" item="item" open="where" separator="or">
			"USERNAME"=#{item.username} AND "GOODS_NO"=#{item.goodsNo}
			
		</foreach>
		
	</delete>
	
	<!--  
	<delete id="delete" parameterType="CartDTO">
		DELETE FROM "TB_CART"
		WHERE "USERNAME"=#{username} AND "GOODS_NO"=#{goodsNo}
	</delete>
  -->
  
  
  
  
  
  
  
  </mapper>